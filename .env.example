# Plantilla de variables de entorno para el monorepo de servicios.
# Copia a `.env` y rellena valores reales. NUNCA commitees el `.env` real.
# Los 4 servicios comparten la MISMA DB, SECRET_KEY y ENCRYPTION_KEY.

# --- Base de datos (compartida por los 4 servicios) ---
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=
# Override directo (usado por tests / docker-compose). Si se define, ignora las DB_* de arriba.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Fallback local si falla la conexión a la principal.
# LOCAL_URL=postgresql://postgres:postgres@localhost:5432/salud_prenatal

# --- Seguridad (DEBE ser idéntica en los 4 servicios) ---
SECRET_KEY=            # firma de JWT (HS256) (solo backend de tests o local sin Vault)
ENCRYPTION_KEY=        # clave Fernet para EncryptedString (urlsafe base64, 32 bytes)

# --- Vault JWT (RS256) ---
# En entornos de despliegue, el JWT_KEY_BACKEND será 'vault'. 
# Esto ignora la SECRET_KEY anterior y firma/valida vía asimétrica.
# JWT_KEY_BACKEND=vault
# VAULT_ADDR=http://localhost:8200
# VAULT_ROLE_ID_AUTH=
# VAULT_SECRET_ID_AUTH=
# VAULT_ROLE_ID_GATEWAY=
# VAULT_SECRET_ID_GATEWAY=

# --- Botón "Authorize" de Swagger (opcional, solo dev) ---
# El login vive únicamente en el servicio auth. Sin esto, "Authorize" en el Swagger
# de pagos/usuarios/transaccional intenta loguearse contra SU PROPIO puerto y falla
# (404 — ese servicio no tiene /login). Debe apuntar al EDGE (Traefik, :8000): los
# requests del "try it out" tienen que pasar por el ForwardAuth para ganar identidad;
# si van directo al puerto del servicio, llegan sin headers X-User-* y dan 401.
# Es localhost porque quien hace el fetch es el navegador del host, no un contenedor.
# AUTH_LOGIN_URL=http://localhost:8000/api/v1/users/login

# --- Traefik / TLS (solo VPS) ---
# Email de registro para los certificados Let's Encrypt (avisos de expiración).
# ACME_EMAIL=

# --- Servicio de ML/NLP externo (lo consume transaccional) ---
ML_SERVICE_URL=
# NLP_TIMEOUT=8.0
# ML_MODEL_VERSION=

# --- Stripe (solo el servicio pagos) ---
STRIPE_PUBLIC_KEY=
STRIPE_PRIVATE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=
STRIPE_PRICE_ID_PREMIUM=

# --- Frontend ---
FRONTEND_URL=
